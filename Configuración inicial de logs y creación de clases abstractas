# 2. EXCEPCIONES PERSONALIZADAS 
class ErrorSistemaFJ(Exception):
    """Clase base para excepciones personalizadas del sistema."""
    pass

class ClienteInvalidoError(ErrorSistemaFJ):
    """Excepción lanzada cuando los datos del cliente son incorrectos."""
    pass

class ServicioNoDisponibleError(ErrorSistemaFJ):
    """Excepción lanzada cuando un servicio no puede ser procesado."""
    pass

class ReservaInvalidaError(ErrorSistemaFJ):
    """Excepción lanzada por errores en el cálculo o estado de la reserva."""
    pass

# 3. CLASES ABSTRACTAS [cite: 193, 195]
class EntidadGeneral(ABC):
    """Clase abstracta que representa entidades generales del sistema."""
    @abstractmethod
    def mostrar_detalle(self):
        pass

class Servicio(EntidadGeneral, ABC):
    """Clase abstracta para los servicios, define el contrato de sus hijos."""
    def __init__(self, codigo, nombre, tarifa_base):
        self.codigo = codigo
        self.nombre = nombre
        self.tarifa_base = tarifa_base

    # Simulamos sobrecarga de métodos mediante parámetros con valores por defecto 
    @abstractmethod
    def calcular_costo(self, duracion, impuesto=0.0, descuento=0.0):
        pass

# 4. CLASE CLIENTE CON ENCAPSULACIÓN Implementación de la clase Cliente con encapsulamiento y validación estricta
class Cliente(EntidadGeneral):
    def __init__(self, identificacion, nombre, correo):
        self.__identificacion = identificacion
        self.__nombre = nombre
        self.correo = correo  # Usa el property setter para validar

    @property
    def correo(self):
        return self.__correo

@correo.setter
    def correo(self, valor):
        # Validación estricta manejando errores de datos inválidos [cite: 191]
        if "@" not in valor or "." not in valor:
            raise ClienteInvalidoError(f"El correo '{valor}' no tiene un formato válido.")
        self.__correo = valor
        
    def mostrar_detalle(self):
        return f"Cliente: {self.__nombre} (ID: {self.__identificacion})"

# 5. CLASES DERIVADAS DE SERVICIO (POLIMORFISMO) [cite: 195, 196]
class ReservaSala(Servicio):
    def calcular_costo(self, duracion, impuesto=0.0, descuento=0.0):
        costo = (self.tarifa_base * duracion)
        return costo + (costo * impuesto) - descuento

    def mostrar_detalle(self):
        return f"Sala: {self.nombre} - Tarifa/hora: ${self.tarifa_base}"

class AlquilerEquipo(Servicio):
    def calcular_costo(self, duracion, impuesto=0.0, descuento=0.0):
        # Los equipos tienen un recargo de seguro fijo
        costo = (self.tarifa_base * duracion) + 15000 
        return costo + (costo * impuesto) - descuento

    def mostrar_detalle(self):
        return f"Equipo: {self.nombre} - Tarifa/día: ${self.tarifa_base}"

class AsesoriaEspecializada(Servicio):
    def calcular_costo(self, duracion, impuesto=0.0, descuento=0.0):
        # Asesorías cobran por sesión completa, independientemente de la duración exacta
        costo = self.tarifa_base
        return costo + (costo * impuesto) - descuento

    def mostrar_detalle(self):
        return f"Asesoría: {self.nombre} - Costo sesión: ${self.tarifa_base}"

# 6. CLASE RESERVA CON MANEJO AVANZADO DE EXCEPCIONES [cite: 197]
class Reserva:
    def __init__(self, cliente, servicio, duracion):
        self.cliente = cliente
        self.servicio = servicio
        self.duracion = duracion
        self.estado = "Pendiente"
        self.costo_total = 0

    def procesar_reserva(self):
        """Uso de bloques try/except/else/finally"""
        print("\n--- Iniciando procesamiento de reserva ---")
        try:
            # 1. Primero validamos que los objetos existan y sean del tipo correcto
            if not isinstance(self.cliente, Cliente):
                raise ReservaInvalidaError("El cliente asignado no es válido o es nulo.")
            if not isinstance(self.servicio, Servicio):
                raise ServicioNoDisponibleError("El servicio solicitado no es válido.")
            
            # 2. Si pasamos las validaciones, ahora sí podemos usar sus métodos sin riesgo
            print(f"Procesando reserva para: {self.cliente.mostrar_detalle()}")
            
            if self.duracion <= 0:
                # Encadenamiento de excepciones
                error_base = ValueError("La duración debe ser mayor a cero.")
                raise ReservaInvalidaError("Cálculo inconsistente debido a duración errónea.") from error_base

            # Polimorfismo en acción: cada servicio calcula el costo a su manera
            self.costo_total = self.servicio.calcular_costo(self.duracion, impuesto=0.19)
            
        except ErrorSistemaFJ as e:
            # Registro en archivo logs
            logging.error(f"Fallo en procesamiento: {e.__class__.__name__} - {e}")
            self.estado = "Fallida"
            print(f"Error procesando: {e}")
        except Exception as e:
            logging.error(f"Error crítico inesperado: {e}")
            self.estado = "Cancelada por error del sistema"
            print("Ocurrió un error inesperado, revisa los logs.")
        else:
            # Se ejecuta solo si NO hubo excepciones
            self.estado = "Confirmada"
            print(f"Reserva confirmada exitosamente. Costo Total: ${self.costo_total}")
        finally:
            # Se ejecuta siempre, ideal para liberar recursos o confirmar estados
            print(f"Estado final de la operación: {self.estado}")
